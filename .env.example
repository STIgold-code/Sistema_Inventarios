# Base de datos (PostgreSQL 17)
DATABASE_URL="postgresql://usuario:clave@localhost:5432/bm_inventarios?schema=public"

# Auth
JWT_SECRET="secreto-largo-y-aleatorio"
# Vida del access token (corto). El refresh token cubre la sesion larga.
JWT_EXPIRACION="1h"
# Vigencia del refresh token en dias (renovacion silenciosa).
JWT_REFRESH_DIAS="30"

# API
API_PUERTO=4021

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4021"
