// Sistema de Inventarios BM Ingenieros
// Decision central: el kardex es un LEDGER INMUTABLE (append-only).
// El stock actual es una PROYECCION cacheada (ItemStock).
// La valuacion usa CAPAS DE COSTO. Cumple SUNAT (Formato 12.1 / 13.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// ENUMS DE DOMINIO (espejo de @bm/tipos/dominio)
// ===========================================================================

enum TipoMovimiento {
  ENTRADA_COMPRA
  ENTRADA_AJUSTE
  ENTRADA_TRANSFERENCIA
  ENTRADA_DEVOLUCION
  ENTRADA_INICIAL
  SALIDA_VENTA
  SALIDA_AJUSTE
  SALIDA_TRANSFERENCIA
  SALIDA_MERMA
  SALIDA_CONSUMO
}

enum SignoMovimiento {
  ENTRADA
  SALIDA
}

enum TipoDocumentoOrigen {
  ORDEN_COMPRA
  RECEPCION
  VENTA
  AJUSTE
  TRANSFERENCIA
  CONTEO_FISICO
  INICIAL
  VALE_SALIDA
}

enum EstadoValeSalida {
  BORRADOR
  AUTORIZADO
  DESPACHADO
  ANULADO
}

enum EstadoLote {
  ACTIVO
  AGOTADO
  BLOQUEADO
  VENCIDO
}

enum MetodoDepreciacion {
  LINEAL
  ACELERADA
}

enum EstadoActivo {
  OPERATIVO
  EN_REPARACION
  BAJA
  EXTRAVIADO
}

enum EstadoCierrePeriodo {
  ABIERTO
  CERRADO
}

enum EstadoSerieArticulo {
  DISPONIBLE
  DESPACHADO
}

enum EstadoOrdenTrabajo {
  ABIERTA
  CERRADA
}

// ===========================================================================
// NUCLEO ORGANIZACIONAL
// ===========================================================================

model Empresa {
  id          BigInt   @id @default(autoincrement())
  ruc         String   @unique @db.VarChar(11)
  razonSocial String   @map("razon_social")
  nombre      String
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now()) @map("creado_en")

  sucursales    Sucursal[]
  familias      Familia[]
  unidades      Unidad[]
  productos     Producto[]
  usuarios      Usuario[]
  roles         Rol[]
  centrosCosto  CentroCosto[]
  correlativos  DocumentoCorrelativo[]
  clientes      Cliente[]
  guiasRemision GuiaRemision[]
  tiposCambio   TipoCambioDiario[]
  cierres       CierrePeriodo[]

  @@map("empresa")
}

model Sucursal {
  id        BigInt @id @default(autoincrement())
  empresaId BigInt @map("empresa_id")
  codigo    String
  nombre    String

  empresa   Empresa      @relation(fields: [empresaId], references: [id])
  almacenes Almacen[]
  activos   ActivoFijo[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@map("sucursal")
}

model Almacen {
  id         BigInt @id @default(autoincrement())
  empresaId  BigInt @map("empresa_id")
  sucursalId BigInt @map("sucursal_id")
  codigo     String
  nombre     String

  sucursal     Sucursal     @relation(fields: [sucursalId], references: [id])
  ubicaciones  Ubicacion[]
  valesSalida  ValeSalida[]
  series       SerieArticulo[]

  @@unique([empresaId, codigo])
  @@index([empresaId, sucursalId])
  @@map("almacen")
}

model Ubicacion {
  id          BigInt  @id @default(autoincrement())
  empresaId   BigInt  @map("empresa_id")
  almacenId   BigInt  @map("almacen_id")
  codigo      String
  descripcion String?

  almacen Almacen @relation(fields: [almacenId], references: [id])

  @@unique([almacenId, codigo])
  @@index([empresaId, almacenId])
  @@map("ubicacion")
}

// ===========================================================================
// MAESTROS TRANSVERSALES: Centro de costo y correlativos de documento
// ===========================================================================

/// Centro de costo para imputacion contable/operativa (ej. ADM, OBR).
model CentroCosto {
  id        BigInt   @id @default(autoincrement())
  empresaId BigInt   @map("empresa_id")
  codigo    String
  nombre    String
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  requerimientos RequerimientoCompra[]
  valesSalida    ValeSalida[]
  ordenesTrabajo OrdenTrabajo[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@map("centro_costo")
}

/// Correlativo atomico por (empresa, tipo de documento, serie).
/// El incremento se hace dentro de una transaccion via upsert.
model DocumentoCorrelativo {
  id            BigInt   @id @default(autoincrement())
  empresaId     BigInt   @map("empresa_id")
  tipoDocumento String   @map("tipo_documento") // REQUERIMIENTO, ORDEN_COMPRA, VALE_SALIDA...
  serie         String   @default("")
  ultimoNumero  Int      @default(0) @map("ultimo_numero")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, tipoDocumento, serie])
  @@index([empresaId])
  @@map("documento_correlativo")
}

/// Tipo de cambio diario por empresa (PEN respecto a USD).
/// `compra` y `venta` son las cotizaciones publicadas (ej. SUNAT/SBS).
/// Unico por (empresa, fecha). La valuacion en USD del kardex usa este TC.
model TipoCambioDiario {
  id            BigInt   @id @default(autoincrement())
  empresaId     BigInt   @map("empresa_id")
  fecha         DateTime @db.Date
  compra        Decimal  @db.Decimal(20, 6)
  venta         Decimal  @db.Decimal(20, 6)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, fecha])
  @@index([empresaId, fecha])
  @@map("tipo_cambio_diario")
}

// ===========================================================================
// CATALOGO: Familia, Unidad, Producto, Sku
// ===========================================================================

model Familia {
  id        BigInt @id @default(autoincrement())
  empresaId BigInt @map("empresa_id")
  codigo    String // "001", "004" (los 3 primeros digitos del codigo parlante)
  nombre    String

  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  productos Producto[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@map("familia")
}

model Unidad {
  id        BigInt @id @default(autoincrement())
  empresaId BigInt @map("empresa_id")
  codigo    String // Tabla 6 SUNAT: KGM, MTR, NIU...
  nombre    String

  empresa            Empresa @relation(fields: [empresaId], references: [id])
  skus               Sku[]   @relation("SkuUnidadControl")
  skusComoReferencia Sku[]   @relation("SkuUnidadReferencia")

  @@unique([empresaId, codigo])
  @@map("unidad")
}

model Producto {
  id          BigInt   @id @default(autoincrement())
  empresaId   BigInt   @map("empresa_id")
  familiaId   BigInt   @map("familia_id")
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now()) @map("creado_en")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  familia Familia @relation(fields: [familiaId], references: [id])
  skus    Sku[]

  @@index([empresaId, familiaId])
  @@map("producto")
}

model Sku {
  id         BigInt @id @default(autoincrement())
  empresaId  BigInt @map("empresa_id")
  productoId BigInt @map("producto_id")

  // Codigo parlante historico de 14 digitos (identificador legible de Excel).
  codigoParlante String  @map("codigo_parlante") @db.VarChar(14)
  // Codigo UNSPSC de 16 digitos para el PLE SUNAT. SEPARADO del parlante.
  codigoUnspsc   String? @map("codigo_unspsc") @db.VarChar(16)
  codigoBarras   String? @map("codigo_barras")

  unidadId BigInt  @map("unidad_id")
  nombre   String?

  // Multi-unidad: unidad de referencia opcional para captura en compras/ventas/vales.
  // factorConversion = cuantas unidades de CONTROL (unidadId) equivalen a UNA unidad
  // de referencia. cantidadControl = cantidadReferencia * factorConversion.
  // Null/1 => sin conversion (la captura ya esta en unidad de control).
  unidadReferenciaId BigInt?  @map("unidad_referencia_id")
  factorConversion   Decimal? @map("factor_conversion") @db.Decimal(20, 8)

  // SUNAT
  tipoExistencia  String @default("01") @map("tipo_existencia") @db.VarChar(2) // Tabla 5
  metodoValuacion String @default("2") @map("metodo_valuacion") @db.VarChar(2) // Tabla 14 (2 = PROMEDIO)

  // Precios de venta por nivel (multiples listas). El nivel aplicado al facturar
  // o cotizar se decide por Cliente.tipoPrecio (1=publico, 2=distribuidor, 3, 4).
  // Null = sin precio configurado para ese nivel.
  precioPublico      Decimal? @map("precio_publico") @db.Decimal(20, 6)
  precioDistribuidor Decimal? @map("precio_distribuidor") @db.Decimal(20, 6)
  precioVenta3       Decimal? @map("precio_venta_3") @db.Decimal(20, 6)
  precioVenta4       Decimal? @map("precio_venta_4") @db.Decimal(20, 6)
  // Moneda de los precios de venta (ISO-4217: PEN, USD). Null = sin definir.
  monedaVenta        String?  @map("moneda_venta") @db.VarChar(3)

  stockMinimo         Decimal? @map("stock_minimo") @db.Decimal(20, 8)
  // Datos logisticos de reposicion (planificacion de abastecimiento).
  stockMaximo         Decimal? @map("stock_maximo") @db.Decimal(20, 8)
  puntoReposicion     Decimal? @map("punto_reposicion") @db.Decimal(20, 8)
  semanasReposicion   Int?     @map("semanas_reposicion")
  // Clasificacion ABC por valor de consumo: "A", "B" o "C". Null = sin clasificar.
  clasificacionAbc    String?  @map("clasificacion_abc") @db.VarChar(1)
  controlaLote        Boolean  @default(false) @map("controla_lote")
  controlaSerie       Boolean  @default(false) @map("controla_serie")
  controlaVencimiento Boolean  @default(false) @map("controla_vencimiento")
  activo              Boolean  @default(true)
  creadoEn            DateTime @default(now()) @map("creado_en")

  producto         Producto @relation(fields: [productoId], references: [id])
  unidad           Unidad   @relation("SkuUnidadControl", fields: [unidadId], references: [id])
  unidadReferencia Unidad?  @relation("SkuUnidadReferencia", fields: [unidadReferenciaId], references: [id])
  lotes       Lote[]
  items       ItemStock[]
  movimientos MovimientoStock[]
  capas       CapaCosto[]
  saldosPeriodo SaldoPeriodo[]
  series        SerieArticulo[]
  cotizaciones  CotizacionProveedor[]

  @@unique([empresaId, codigoParlante])
  @@index([empresaId, productoId])
  @@map("sku")
}

// ===========================================================================
// STOCK: Lote y posicion fisica (ItemStock = proyeccion cacheada)
// ===========================================================================

model Lote {
  id               BigInt     @id @default(autoincrement())
  empresaId        BigInt     @map("empresa_id")
  skuId            BigInt     @map("sku_id")
  codigo           String
  fechaVencimiento DateTime?  @map("fecha_vencimiento")
  estado           EstadoLote @default(ACTIVO)

  sku Sku @relation(fields: [skuId], references: [id])

  @@unique([empresaId, skuId, codigo])
  @@index([empresaId, skuId, fechaVencimiento])
  @@map("lote")
}

/// Proyeccion del stock por posicion fisica. Cacheada, NO es la fuente de verdad.
model ItemStock {
  id          BigInt  @id @default(autoincrement())
  empresaId   BigInt  @map("empresa_id")
  skuId       BigInt  @map("sku_id")
  almacenId   BigInt  @map("almacen_id")
  ubicacionId BigInt? @map("ubicacion_id")
  loteId      BigInt? @map("lote_id")
  serie       String?

  cantidadDisponible   Decimal @default(0) @map("cantidad_disponible") @db.Decimal(20, 8)
  cantidadComprometida Decimal @default(0) @map("cantidad_comprometida") @db.Decimal(20, 8)
  costoPromedio        Decimal @default(0) @map("costo_promedio") @db.Decimal(20, 8)
  version              Int     @default(0)

  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  sku         Sku               @relation(fields: [skuId], references: [id])
  movimientos MovimientoStock[]

  @@unique([empresaId, skuId, almacenId, ubicacionId, loteId, serie], name: "posicion")
  @@index([empresaId, skuId, almacenId])
  @@map("item_stock")
}

// ===========================================================================
// LEDGER INMUTABLE (kardex) — con campos SUNAT para Formato 12.1 / 13.1
// ===========================================================================

model MovimientoStock {
  id          BigInt @id @default(autoincrement())
  empresaId   BigInt @map("empresa_id")
  skuId       BigInt @map("sku_id")
  almacenId   BigInt @map("almacen_id")
  itemStockId BigInt @map("item_stock_id")
  loteId      BigInt? @map("lote_id")

  tipo  TipoMovimiento
  signo SignoMovimiento

  cantidad      Decimal @db.Decimal(20, 8)
  costoUnitario Decimal @map("costo_unitario") @db.Decimal(20, 8)
  costoTotal    Decimal @map("costo_total") @db.Decimal(20, 2)

  // Valorizacion bimoneda (USD). Null cuando no hay tipo de cambio del dia.
  // Se deriva del costo en soles: costoUsd = costoSoles / tipoCambio.
  costoUnitarioUsd Decimal? @map("costo_unitario_usd") @db.Decimal(20, 8)
  costoTotalUsd    Decimal? @map("costo_total_usd") @db.Decimal(20, 2)

  // Saldo resultante (snapshot que SUNAT exige guardar en cada movimiento).
  saldoCantidad      Decimal @map("saldo_cantidad") @db.Decimal(20, 8)
  saldoCostoUnitario Decimal @map("saldo_costo_unitario") @db.Decimal(20, 8)
  saldoCostoTotal    Decimal @map("saldo_costo_total") @db.Decimal(20, 2)

  // Documento origen (polimorfico ligero)
  documentoTipo TipoDocumentoOrigen @map("documento_tipo")
  documentoId   BigInt?             @map("documento_id")

  // --- Campos SUNAT (Formato 12.1 / 13.1) ---
  periodo                 String  @db.VarChar(6) // AAAAMM
  fechaEmisionDocumento   DateTime @map("fecha_emision_documento")
  cuo                     String  @db.VarChar(40) // Codigo Unico de Operacion (= Libro Diario)
  numeroCorrelativo       String  @map("numero_correlativo")
  secuencia               BigInt  // entero monotonico para desempate del kardex
  indicadorEstado         String  @default("1") @map("indicador_estado") @db.VarChar(1)
  tipoDocumentoSunat      String  @map("tipo_documento_sunat") @db.VarChar(2) // Tabla 10
  serieComprobante        String  @default("0") @map("serie_comprobante")
  numeroComprobante       String  @default("0") @map("numero_comprobante")
  tipoOperacionSunat      String  @map("tipo_operacion_sunat") @db.VarChar(2) // Tabla 12

  usuarioId       BigInt   @map("usuario_id")
  fechaMovimiento DateTime @default(now()) @map("fecha_movimiento")
  observaciones   String?

  sku       Sku       @relation(fields: [skuId], references: [id])
  itemStock ItemStock @relation(fields: [itemStockId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])
  consumos  ConsumoCapa[]
  capaCreada CapaCosto?
  seriesEntrada SerieArticulo[] @relation("SerieMovimientoEntrada")
  seriesSalida  SerieArticulo[] @relation("SerieMovimientoSalida")

  @@index([empresaId, skuId, fechaMovimiento, secuencia])
  @@index([empresaId, almacenId, fechaMovimiento])
  @@index([empresaId, periodo])
  @@index([documentoTipo, documentoId])
  @@map("movimiento_stock")
}

// ===========================================================================
// CAPAS DE COSTO (FIFO) y su consumo
// ===========================================================================

/// Una capa por cada ENTRADA. Las salidas consumen capas en orden FIFO.
model CapaCosto {
  id                  BigInt  @id @default(autoincrement())
  empresaId           BigInt  @map("empresa_id")
  skuId               BigInt  @map("sku_id")
  almacenId           BigInt  @map("almacen_id")
  loteId              BigInt? @map("lote_id")
  movimientoEntradaId BigInt  @unique @map("movimiento_entrada_id")

  cantidadInicial  Decimal  @map("cantidad_inicial") @db.Decimal(20, 8)
  cantidadRestante Decimal  @map("cantidad_restante") @db.Decimal(20, 8)
  costoUnitario    Decimal  @map("costo_unitario") @db.Decimal(20, 8)
  // Costo unitario en USD al ingreso de la capa (null si no habia TC ese dia).
  costoUnitarioUsd Decimal? @map("costo_unitario_usd") @db.Decimal(20, 8)
  fechaIngreso     DateTime @default(now()) @map("fecha_ingreso")
  agotada          Boolean  @default(false)

  sku               Sku             @relation(fields: [skuId], references: [id])
  movimientoEntrada MovimientoStock @relation(fields: [movimientoEntradaId], references: [id])
  consumos          ConsumoCapa[]

  @@index([empresaId, skuId, almacenId, agotada, fechaIngreso])
  @@map("capa_costo")
}

/// Detalle de consumo de capas por cada salida (auditoria del costeo FIFO).
model ConsumoCapa {
  id                 BigInt  @id @default(autoincrement())
  empresaId          BigInt  @map("empresa_id")
  movimientoSalidaId BigInt  @map("movimiento_salida_id")
  capaCostoId        BigInt  @map("capa_costo_id")
  cantidad           Decimal @db.Decimal(20, 8)
  costoUnitario      Decimal @map("costo_unitario") @db.Decimal(20, 8)

  movimientoSalida MovimientoStock @relation(fields: [movimientoSalidaId], references: [id])
  capaCosto        CapaCosto       @relation(fields: [capaCostoId], references: [id])

  @@index([movimientoSalidaId])
  @@index([capaCostoId])
  @@map("consumo_capa")
}

// ===========================================================================
// USUARIOS / ROLES / PERMISOS
// ===========================================================================

model Usuario {
  id        BigInt   @id @default(autoincrement())
  empresaId BigInt   @map("empresa_id")
  email     String
  hashClave String   @map("hash_clave")
  nombre    String
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  empresa     Empresa           @relation(fields: [empresaId], references: [id])
  roles       UsuarioRol[]
  movimientos MovimientoStock[]
  requerimientosSolicitados RequerimientoCompra[] @relation("RequerimientoSolicitante")
  requerimientosAprobados   RequerimientoCompra[] @relation("RequerimientoAprobador")
  ordenesAprobadas          OrdenCompra[]         @relation("OrdenCompraAprobador")
  valesSolicitados          ValeSalida[]          @relation("ValeSalidaSolicitante")
  valesAutorizados          ValeSalida[]          @relation("ValeSalidaAutorizador")
  cierresRealizados         CierrePeriodo[]       @relation("CierrePeriodoCerradoPor")

  @@unique([empresaId, email])
  @@map("usuario")
}

model Rol {
  id        BigInt @id @default(autoincrement())
  empresaId BigInt @map("empresa_id")
  codigo    String // ADMIN, ALMACENERO, COMPRAS, VENTAS, AUDITOR
  nombre    String

  empresa  Empresa      @relation(fields: [empresaId], references: [id])
  permisos RolPermiso[]
  usuarios UsuarioRol[]

  @@unique([empresaId, codigo])
  @@map("rol")
}

model Permiso {
  id     BigInt @id @default(autoincrement())
  codigo String @unique // "inventario.movimiento.crear", "producto.editar"
  nombre String

  roles RolPermiso[]

  @@map("permiso")
}

model RolPermiso {
  rolId     BigInt @map("rol_id")
  permisoId BigInt @map("permiso_id")

  rol     Rol     @relation(fields: [rolId], references: [id])
  permiso Permiso @relation(fields: [permisoId], references: [id])

  @@id([rolId, permisoId])
  @@map("rol_permiso")
}

model UsuarioRol {
  usuarioId BigInt @map("usuario_id")
  rolId     BigInt @map("rol_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  rol     Rol     @relation(fields: [rolId], references: [id])

  @@id([usuarioId, rolId])
  @@map("usuario_rol")
}

// ===========================================================================
// COMPRAS: Proveedor, Orden de Compra, Recepcion (parcial)
// ===========================================================================

enum EstadoOrdenCompra {
  BORRADOR
  EMITIDA
  PARCIAL
  COMPLETA
  ANULADA
}

enum EstadoRequerimiento {
  BORRADOR
  APROBADO
  RECHAZADO
  CONVERTIDO
}

model RequerimientoCompra {
  id            BigInt              @id @default(autoincrement())
  empresaId     BigInt              @map("empresa_id")
  numero        String // correlativo interno (tipo REQUERIMIENTO)
  fecha         DateTime            @default(now())
  centroCostoId BigInt              @map("centro_costo_id")
  solicitanteId BigInt              @map("solicitante_id")
  estado        EstadoRequerimiento @default(BORRADOR)
  aprobadoPorId BigInt?             @map("aprobado_por_id")
  observaciones String?
  creadoEn      DateTime            @default(now()) @map("creado_en")
  actualizadoEn DateTime            @updatedAt @map("actualizado_en")

  centroCosto CentroCosto                  @relation(fields: [centroCostoId], references: [id])
  solicitante Usuario                      @relation("RequerimientoSolicitante", fields: [solicitanteId], references: [id])
  aprobadoPor Usuario?                     @relation("RequerimientoAprobador", fields: [aprobadoPorId], references: [id])
  lineas      RequerimientoCompraLinea[]
  ordenes     OrdenCompra[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@map("requerimiento_compra")
}

model RequerimientoCompraLinea {
  id               BigInt  @id @default(autoincrement())
  empresaId        BigInt  @map("empresa_id")
  requerimientoId  BigInt  @map("requerimiento_id")
  skuId            BigInt  @map("sku_id")
  cantidad         Decimal @db.Decimal(20, 8)
  justificacion    String?

  requerimiento RequerimientoCompra @relation(fields: [requerimientoId], references: [id])

  @@index([requerimientoId])
  @@index([empresaId, skuId])
  @@map("requerimiento_compra_linea")
}

// ===========================================================================
// VALE DE SALIDA / HOJA DE CARGO: salida interna de almacen (consumo a obra,
// area o centro de costo). Segregacion de funciones: solicita != autoriza.
// ===========================================================================

model ValeSalida {
  id              BigInt           @id @default(autoincrement())
  empresaId       BigInt           @map("empresa_id")
  numero          String // correlativo interno (tipo VALE_SALIDA)
  fecha           DateTime         @default(now())
  almacenId       BigInt           @map("almacen_id") // almacen del que sale el stock
  centroCostoId   BigInt           @map("centro_costo_id")
  ordenTrabajoId  BigInt?          @map("orden_trabajo_id") // OT a la que se imputa el consumo (opcional)
  solicitanteId   BigInt           @map("solicitante_id")
  autorizadoPorId BigInt?          @map("autorizado_por_id")
  destino         String // area / obra / proyecto destino del consumo
  estado          EstadoValeSalida @default(BORRADOR)
  observaciones   String?
  creadoEn        DateTime         @default(now()) @map("creado_en")
  actualizadoEn   DateTime         @updatedAt @map("actualizado_en")

  almacen     Almacen           @relation(fields: [almacenId], references: [id])
  centroCosto CentroCosto       @relation(fields: [centroCostoId], references: [id])
  ordenTrabajo OrdenTrabajo?    @relation(fields: [ordenTrabajoId], references: [id])
  solicitante Usuario           @relation("ValeSalidaSolicitante", fields: [solicitanteId], references: [id])
  autorizadoPor Usuario?        @relation("ValeSalidaAutorizador", fields: [autorizadoPorId], references: [id])
  lineas      ValeSalidaLinea[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@index([empresaId, almacenId])
  @@index([empresaId, ordenTrabajoId])
  @@map("vale_salida")
}

model ValeSalidaLinea {
  id                  BigInt  @id @default(autoincrement())
  empresaId           BigInt  @map("empresa_id")
  valeSalidaId        BigInt  @map("vale_salida_id")
  skuId               BigInt  @map("sku_id")
  cantidad            Decimal @db.Decimal(20, 8)
  cantidadDespachada  Decimal @default(0) @map("cantidad_despachada") @db.Decimal(20, 8)
  observacion         String?
  movimientoStockId   BigInt? @map("movimiento_stock_id") // salida generada en el ledger

  valeSalida ValeSalida @relation(fields: [valeSalidaId], references: [id], onDelete: Cascade)

  @@index([valeSalidaId])
  @@index([empresaId, skuId])
  @@map("vale_salida_linea")
}

// ===========================================================================
// ORDEN DE TRABAJO: agrupa el consumo de almacen imputado a un trabajo/proyecto.
// Los vales de salida (consumo) se asocian opcionalmente a una OT para
// obtener el consumo valorizado acumulado por OT desde el ledger.
// ===========================================================================

model OrdenTrabajo {
  id            BigInt             @id @default(autoincrement())
  empresaId     BigInt             @map("empresa_id")
  numero        String // correlativo interno (tipo ORDEN_TRABAJO)
  descripcion   String
  centroCostoId BigInt             @map("centro_costo_id")
  estado        EstadoOrdenTrabajo @default(ABIERTA)
  fechaApertura DateTime           @default(now()) @map("fecha_apertura")
  fechaCierre   DateTime?          @map("fecha_cierre")
  creadoEn      DateTime           @default(now()) @map("creado_en")
  actualizadoEn DateTime           @updatedAt @map("actualizado_en")

  centroCosto CentroCosto  @relation(fields: [centroCostoId], references: [id])
  valesSalida ValeSalida[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@index([empresaId, centroCostoId])
  @@map("orden_trabajo")
}

model Proveedor {
  id        BigInt   @id @default(autoincrement())
  empresaId BigInt   @map("empresa_id")
  ruc       String   @db.VarChar(11)
  razonSocial String @map("razon_social")
  direccion String?
  telefono  String?
  email     String?
  condicionPago    String? @map("condicion_pago") // CONTADO, CREDITO_30...
  monedaHabitual   String  @default("PEN") @map("moneda_habitual")
  cci              String?
  contactoNombre   String? @map("contacto_nombre")
  tipoDocIdentidad String  @default("6") @map("tipo_doc_identidad") @db.VarChar(2) // Tabla 2 (6=RUC)
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  ordenes     OrdenCompra[]
  cotizaciones CotizacionProveedor[]

  @@unique([empresaId, ruc])
  @@index([empresaId])
  @@map("proveedor")
}

// Cotizacion proveedor-articulo: historico de precios ofertados por un proveedor
// para un SKU. Permite consultar el ultimo precio por proveedor por articulo.
model CotizacionProveedor {
  id              BigInt   @id @default(autoincrement())
  empresaId       BigInt   @map("empresa_id")
  proveedorId     BigInt   @map("proveedor_id")
  skuId           BigInt   @map("sku_id")
  moneda          String   @default("PEN")
  precioUnitario  Decimal  @map("precio_unitario") @db.Decimal(20, 6)
  fechaCotizacion DateTime @map("fecha_cotizacion")
  numeroCotizacion String? @map("numero_cotizacion")
  ordenCompraRef  String?  @map("orden_compra_ref")
  creadoEn        DateTime @default(now()) @map("creado_en")

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  sku       Sku       @relation(fields: [skuId], references: [id])

  // Orden cronologico para resolver "ultimo precio" por (proveedor, sku).
  @@index([empresaId, skuId, fechaCotizacion])
  @@index([empresaId, proveedorId, skuId, fechaCotizacion])
  @@map("cotizacion_proveedor")
}

model OrdenCompra {
  id          BigInt            @id @default(autoincrement())
  empresaId   BigInt            @map("empresa_id")
  proveedorId BigInt            @map("proveedor_id")
  almacenId   BigInt            @map("almacen_id") // almacen de recepcion
  requerimientoId BigInt?       @map("requerimiento_id")
  numero      String // correlativo interno de la OC
  estado      EstadoOrdenCompra @default(BORRADOR)
  fechaEmision DateTime         @default(now()) @map("fecha_emision")
  moneda      String            @default("PEN")
  tipoCambio  Decimal?          @map("tipo_cambio") @db.Decimal(20, 6)
  subtotal    Decimal           @default(0) @db.Decimal(20, 2)
  igv         Decimal           @default(0) @db.Decimal(20, 2)
  total       Decimal           @default(0) @db.Decimal(20, 2)
  observaciones String?
  usuarioId   BigInt            @map("usuario_id")
  aprobadoPorId BigInt?         @map("aprobado_por_id")

  proveedor     Proveedor           @relation(fields: [proveedorId], references: [id])
  requerimiento RequerimientoCompra? @relation(fields: [requerimientoId], references: [id])
  aprobadoPor   Usuario?            @relation("OrdenCompraAprobador", fields: [aprobadoPorId], references: [id])
  lineas        OrdenCompraLinea[]
  recepciones   Recepcion[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@map("orden_compra")
}

model OrdenCompraLinea {
  id            BigInt  @id @default(autoincrement())
  empresaId     BigInt  @map("empresa_id")
  ordenCompraId BigInt  @map("orden_compra_id")
  skuId         BigInt  @map("sku_id")
  cantidad      Decimal @db.Decimal(20, 8)
  costoUnitario Decimal @map("costo_unitario") @db.Decimal(20, 8)
  cantidadRecibida Decimal @default(0) @map("cantidad_recibida") @db.Decimal(20, 8)

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id])

  @@index([ordenCompraId])
  @@index([empresaId, skuId])
  @@map("orden_compra_linea")
}

model Recepcion {
  id            BigInt   @id @default(autoincrement())
  empresaId     BigInt   @map("empresa_id")
  ordenCompraId BigInt   @map("orden_compra_id")
  fecha         DateTime @default(now())
  // Comprobante del proveedor (OBLIGATORIO): toda recepcion nace de una factura.
  tipoDocumentoSunat String @default("01") @map("tipo_documento_sunat") @db.VarChar(2) // Tabla 10
  serieComprobante String @map("serie_comprobante")
  numeroComprobante String @map("numero_comprobante")
  fechaEmisionDocumento DateTime @map("fecha_emision_documento")
  moneda        String   @default("PEN")
  tipoCambio    Decimal? @map("tipo_cambio") @db.Decimal(20, 6)
  subtotal      Decimal  @db.Decimal(20, 2)
  igv           Decimal  @db.Decimal(20, 2)
  total         Decimal  @db.Decimal(20, 2)
  guiaRemisionProveedor String? @map("guia_remision_proveedor") // serie-numero de la guia del proveedor
  usuarioId     BigInt   @map("usuario_id")

  ordenCompra OrdenCompra      @relation(fields: [ordenCompraId], references: [id])
  lineas      RecepcionLinea[]

  @@index([empresaId, ordenCompraId])
  @@map("recepcion")
}

model RecepcionLinea {
  id            BigInt  @id @default(autoincrement())
  empresaId     BigInt  @map("empresa_id")
  recepcionId   BigInt  @map("recepcion_id")
  ordenCompraLineaId BigInt @map("orden_compra_linea_id")
  skuId         BigInt  @map("sku_id")
  cantidad      Decimal @db.Decimal(20, 8)
  movimientoStockId BigInt @map("movimiento_stock_id") // entrada generada en el ledger

  recepcion Recepcion @relation(fields: [recepcionId], references: [id])

  @@index([recepcionId])
  @@map("recepcion_linea")
}

// ===========================================================================
// VENTAS: Orden de venta con reserva y despacho
// ===========================================================================

enum EstadoOrdenVenta {
  PENDIENTE
  PARCIAL
  DESPACHADA
  ANULADA
}

/// Maestro de clientes (espejo de Proveedor). El comprobante de venta se emite
/// a su nombre. tipoDocIdentidad usa la Tabla 2 SUNAT (6=RUC, 1=DNI).
model Cliente {
  id               BigInt   @id @default(autoincrement())
  empresaId        BigInt   @map("empresa_id")
  tipoDocIdentidad String   @default("6") @map("tipo_doc_identidad") @db.VarChar(2) // Tabla 2 (6=RUC, 1=DNI)
  numeroDoc        String   @map("numero_doc")
  razonSocial      String   @map("razon_social")
  direccion        String?
  telefono         String?
  email            String?
  // Nivel de precio de venta aplicado a este cliente (mapea a las listas del SKU):
  // 1=publico, 2=distribuidor, 3, 4. Null => se asume publico (1) al sugerir precio.
  tipoPrecio       Int?     @map("tipo_precio")
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  ordenes      OrdenVenta[]
  comprobantes ComprobanteVenta[]

  @@unique([empresaId, numeroDoc])
  @@index([empresaId])
  @@map("cliente")
}

model OrdenVenta {
  id           BigInt           @id @default(autoincrement())
  empresaId    BigInt           @map("empresa_id")
  almacenId    BigInt           @map("almacen_id")
  clienteId    BigInt?          @map("cliente_id") // FK al maestro Cliente (preferido)
  numero       String
  cliente      String?          // texto libre legacy/fallback (deprecado, usar clienteId)
  estado       EstadoOrdenVenta @default(PENDIENTE)
  fechaEmision DateTime         @default(now()) @map("fecha_emision")
  moneda       String           @default("PEN")
  tipoCambio   Decimal?         @map("tipo_cambio") @db.Decimal(20, 6)
  subtotal     Decimal          @default(0) @db.Decimal(20, 2)
  igv          Decimal          @default(0) @db.Decimal(20, 2)
  total        Decimal          @default(0) @db.Decimal(20, 2)
  observaciones String?
  usuarioId    BigInt           @map("usuario_id")

  clienteRef   Cliente?           @relation(fields: [clienteId], references: [id])
  lineas       OrdenVentaLinea[]
  comprobantes ComprobanteVenta[]
  guiasRemision GuiaRemision[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@map("orden_venta")
}

model OrdenVentaLinea {
  id           BigInt  @id @default(autoincrement())
  empresaId    BigInt  @map("empresa_id")
  ordenVentaId BigInt  @map("orden_venta_id")
  skuId        BigInt  @map("sku_id")
  cantidad     Decimal @db.Decimal(20, 8)
  precioUnitario Decimal @default(0) @map("precio_unitario") @db.Decimal(20, 8)
  cantidadDespachada Decimal @default(0) @map("cantidad_despachada") @db.Decimal(20, 8)

  ordenVenta OrdenVenta @relation(fields: [ordenVentaId], references: [id])

  @@index([ordenVentaId])
  @@index([empresaId, skuId])
  @@map("orden_venta_linea")
}

/// Referencia del comprobante de venta (NO emite electronicamente, solo
/// registra el sustento SUNAT). Un comprobante por despacho de la orden.
model ComprobanteVenta {
  id                 BigInt   @id @default(autoincrement())
  empresaId          BigInt   @map("empresa_id")
  ordenVentaId       BigInt   @map("orden_venta_id")
  clienteId          BigInt   @map("cliente_id")
  tipoDocumentoSunat String   @map("tipo_documento_sunat") @db.VarChar(2) // Tabla 10
  serie              String
  numero             String
  fechaEmision       DateTime @map("fecha_emision")
  moneda             String   @default("PEN")
  tipoCambio         Decimal? @map("tipo_cambio") @db.Decimal(20, 6)
  subtotal           Decimal  @db.Decimal(20, 2)
  igv                Decimal  @db.Decimal(20, 2)
  total              Decimal  @db.Decimal(20, 2)
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  ordenVenta OrdenVenta @relation(fields: [ordenVentaId], references: [id])
  cliente    Cliente    @relation(fields: [clienteId], references: [id])

  @@unique([empresaId, tipoDocumentoSunat, serie, numero])
  @@index([empresaId, ordenVentaId])
  @@map("comprobante_venta")
}

// ===========================================================================
// TRAZABILIDAD: Conteo fisico / cuadre de inventario
// ===========================================================================

enum EstadoConteo {
  ABIERTO
  APLICADO
  ANULADO
}

model ConteoFisico {
  id            BigInt       @id @default(autoincrement())
  empresaId     BigInt       @map("empresa_id")
  almacenId     BigInt       @map("almacen_id")
  estado        EstadoConteo @default(ABIERTO)
  fecha         DateTime     @default(now())
  observaciones String?
  usuarioId     BigInt       @map("usuario_id")

  lineas ConteoLinea[]

  @@index([empresaId, estado])
  @@map("conteo_fisico")
}

model ConteoLinea {
  id              BigInt  @id @default(autoincrement())
  empresaId       BigInt  @map("empresa_id")
  conteoId        BigInt  @map("conteo_id")
  skuId           BigInt  @map("sku_id")
  cantidadSistema Decimal @map("cantidad_sistema") @db.Decimal(20, 8)
  cantidadContada Decimal @map("cantidad_contada") @db.Decimal(20, 8)
  diferencia      Decimal @db.Decimal(20, 8)
  movimientoAjusteId BigInt? @map("movimiento_ajuste_id")

  conteo ConteoFisico @relation(fields: [conteoId], references: [id])

  @@unique([conteoId, skuId])
  @@index([conteoId])
  @@map("conteo_linea")
}

// ===========================================================================
// TRASLADOS entre almacenes (con transito: despacho -> en transito -> recepcion)
// ===========================================================================

enum EstadoTraslado {
  PENDIENTE
  EN_TRANSITO
  RECIBIDO
  ANULADO
}

model Traslado {
  id               BigInt         @id @default(autoincrement())
  empresaId        BigInt         @map("empresa_id")
  numero           String
  almacenOrigenId  BigInt         @map("almacen_origen_id")
  almacenDestinoId BigInt         @map("almacen_destino_id")
  estado           EstadoTraslado @default(PENDIENTE)
  fechaEmision     DateTime       @default(now()) @map("fecha_emision")
  fechaDespacho    DateTime?      @map("fecha_despacho")
  fechaRecepcion   DateTime?      @map("fecha_recepcion")
  observaciones    String?
  usuarioId        BigInt         @map("usuario_id")

  lineas        TrasladoLinea[]
  guiasRemision GuiaRemision[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@map("traslado")
}

/// Referencia de la Guia de Remision Remitente (NO emite la GRE electronica a
/// SUNAT; solo REGISTRA su referencia: serie/numero/motivo/transportista/puntos).
/// Se asocia a un Traslado (motivo "04") O al despacho de una OrdenVenta
/// (motivo "01"). Regla de negocio: exactamente uno de trasladoId/ordenVentaId
/// debe estar presente (validado en el service).
model GuiaRemision {
  id                  BigInt   @id @default(autoincrement())
  empresaId           BigInt   @map("empresa_id")
  serie               String
  numero              String
  fechaTraslado       DateTime @map("fecha_traslado")
  motivoTraslado      String   @map("motivo_traslado") @db.VarChar(2) // Catalogo 20 SUNAT
  transportistaDoc    String?  @map("transportista_doc") // RUC del transportista
  transportistaNombre String?  @map("transportista_nombre")
  puntoPartida        String   @map("punto_partida")
  puntoLlegada        String   @map("punto_llegada")
  pesoBruto           Decimal? @map("peso_bruto") @db.Decimal(20, 3)
  observaciones       String?
  trasladoId          BigInt?  @map("traslado_id")
  ordenVentaId        BigInt?  @map("orden_venta_id")
  creadoEn            DateTime @default(now()) @map("creado_en")
  actualizadoEn       DateTime @updatedAt @map("actualizado_en")

  empresa    Empresa     @relation(fields: [empresaId], references: [id])
  traslado   Traslado?   @relation(fields: [trasladoId], references: [id])
  ordenVenta OrdenVenta? @relation(fields: [ordenVentaId], references: [id])

  @@unique([empresaId, serie, numero])
  @@index([empresaId, trasladoId])
  @@index([empresaId, ordenVentaId])
  @@map("guia_remision")
}

model TrasladoLinea {
  id                BigInt  @id @default(autoincrement())
  empresaId         BigInt  @map("empresa_id")
  trasladoId        BigInt  @map("traslado_id")
  skuId             BigInt  @map("sku_id")
  cantidad          Decimal @db.Decimal(20, 8) // solicitada
  cantidadDespachada Decimal @default(0) @map("cantidad_despachada") @db.Decimal(20, 8)
  cantidadRecibida  Decimal @default(0) @map("cantidad_recibida") @db.Decimal(20, 8)
  costoUnitario     Decimal @default(0) @map("costo_unitario") @db.Decimal(20, 8) // costo al despachar

  traslado Traslado @relation(fields: [trasladoId], references: [id])

  @@index([trasladoId])
  @@index([empresaId, skuId])
  @@map("traslado_linea")
}

// ===========================================================================
// ACTIVOS FIJOS (modulo aparte — no usa ledger ni capas)
// ===========================================================================

model CategoriaActivo {
  id            BigInt  @id @default(autoincrement())
  empresaId     BigInt  @map("empresa_id")
  nombre        String
  vidaUtilMeses Int     @map("vida_util_meses")
  tasaAnual     Decimal @map("tasa_anual") @db.Decimal(7, 4)

  activos ActivoFijo[]

  @@unique([empresaId, nombre])
  @@map("categoria_activo")
}

model ActivoFijo {
  id            BigInt  @id @default(autoincrement())
  empresaId     BigInt  @map("empresa_id")
  sucursalId    BigInt  @map("sucursal_id")
  categoriaId   BigInt  @map("categoria_id")
  codigo        String
  nombre        String
  marca         String?
  modelo        String?
  numeroSerie   String? @map("numero_serie")
  departamento  String?
  responsableId BigInt? @map("responsable_id")

  fechaCompra        DateTime @map("fecha_compra")
  valorAdquisicion   Decimal  @map("valor_adquisicion") @db.Decimal(20, 2)
  valorResidual      Decimal  @default(0) @map("valor_residual") @db.Decimal(20, 2)
  metodoDepreciacion MetodoDepreciacion @default(LINEAL) @map("metodo_depreciacion")
  vidaUtilMeses      Int      @map("vida_util_meses")

  fechaFinGarantia DateTime?    @map("fecha_fin_garantia")
  estado           EstadoActivo @default(OPERATIVO)

  depreciacionAcumulada Decimal @default(0) @map("depreciacion_acumulada") @db.Decimal(20, 2)
  valorActual           Decimal @map("valor_actual") @db.Decimal(20, 2)

  categoria      CategoriaActivo      @relation(fields: [categoriaId], references: [id])
  sucursal       Sucursal             @relation(fields: [sucursalId], references: [id])
  depreciaciones DepreciacionActivo[]

  @@unique([empresaId, codigo])
  @@index([empresaId, sucursalId])
  @@map("activo_fijo")
}

/// Ledger de depreciacion: una fila por periodo (mes). Append-only.
model DepreciacionActivo {
  id             BigInt   @id @default(autoincrement())
  empresaId      BigInt   @map("empresa_id")
  activoId       BigInt   @map("activo_id")
  periodo        String   @db.VarChar(7) // "2026-06"
  montoPeriodo   Decimal  @map("monto_periodo") @db.Decimal(20, 2)
  acumuladoHasta Decimal  @map("acumulado_hasta") @db.Decimal(20, 2)
  valorEnLibros  Decimal  @map("valor_en_libros") @db.Decimal(20, 2)
  generadoEn     DateTime @default(now()) @map("generado_en")

  activo ActivoFijo @relation(fields: [activoId], references: [id])

  @@unique([empresaId, activoId, periodo])
  @@index([empresaId, periodo])
  @@map("depreciacion_activo")
}

// ===========================================================================
// CIERRE MENSUAL DE PERIODO VALORIZADO
// ===========================================================================

/// Cierre contable de un periodo (AAAAMM) por empresa. Al cerrar, se congela el
/// saldo valorizado del inventario al fin del periodo y se bloquea el registro
/// de movimientos con fecha dentro de ese periodo. Solo ADMIN puede reabrir.
model CierrePeriodo {
  id                   BigInt              @id @default(autoincrement())
  empresaId            BigInt              @map("empresa_id")
  periodo              String              @db.VarChar(6) // AAAAMM
  estado               EstadoCierrePeriodo @default(ABIERTO)
  cerradoPorId         BigInt?             @map("cerrado_por_id")
  fechaCierre          DateTime?           @map("fecha_cierre")
  totalValorizadoSoles Decimal             @default(0) @map("total_valorizado_soles") @db.Decimal(20, 2)
  totalValorizadoUsd   Decimal?            @map("total_valorizado_usd") @db.Decimal(20, 2)
  creadoEn             DateTime            @default(now()) @map("creado_en")
  actualizadoEn        DateTime            @updatedAt @map("actualizado_en")

  empresa    Empresa         @relation(fields: [empresaId], references: [id])
  cerradoPor Usuario?        @relation("CierrePeriodoCerradoPor", fields: [cerradoPorId], references: [id])
  saldos     SaldoPeriodo[]

  @@unique([empresaId, periodo])
  @@index([empresaId, estado])
  @@map("cierre_periodo")
}

/// Snapshot inmutable del saldo valorizado por SKU/almacen al cierre de un
/// periodo. Fotografia de auditoria: NO se recalcula despues del cierre.
model SaldoPeriodo {
  id         BigInt   @id @default(autoincrement())
  empresaId  BigInt   @map("empresa_id")
  cierreId   BigInt   @map("cierre_id")
  periodo    String   @db.VarChar(6) // AAAAMM (denormalizado para consultas)
  skuId      BigInt   @map("sku_id")
  almacenId  BigInt   @map("almacen_id")
  cantidad   Decimal  @db.Decimal(20, 8)
  costoSoles Decimal  @map("costo_soles") @db.Decimal(20, 2)
  costoUsd   Decimal? @map("costo_usd") @db.Decimal(20, 2)
  creadoEn   DateTime @default(now()) @map("creado_en")

  cierre CierrePeriodo @relation(fields: [cierreId], references: [id], onDelete: Cascade)
  sku    Sku           @relation(fields: [skuId], references: [id])

  @@unique([cierreId, skuId, almacenId])
  @@index([empresaId, periodo])
  @@map("saldo_periodo")
}

// ===========================================================================
// TRAZABILIDAD POR NUMERO DE SERIE (SKUs con controlaSerie = true)
// ===========================================================================

/// Una fila por numero de serie individual de un articulo serializado. Al
/// ingresar stock de un SKU con controlaSerie se registra cada serie como
/// DISPONIBLE enlazada al movimiento de entrada; al despachar/vender se marca
/// DESPACHADO enlazando el movimiento de salida. El estado/almacen son una
/// proyeccion del ciclo de vida de la serie; los movimientos son la auditoria.
model SerieArticulo {
  id                  BigInt              @id @default(autoincrement())
  empresaId           BigInt              @map("empresa_id")
  skuId               BigInt              @map("sku_id")
  numeroSerie         String              @map("numero_serie")
  almacenId           BigInt?             @map("almacen_id")
  estado              EstadoSerieArticulo @default(DISPONIBLE)
  movimientoEntradaId BigInt?             @map("movimiento_entrada_id")
  movimientoSalidaId  BigInt?             @map("movimiento_salida_id")
  creadoEn            DateTime            @default(now()) @map("creado_en")
  actualizadoEn       DateTime            @updatedAt @map("actualizado_en")

  sku               Sku              @relation(fields: [skuId], references: [id])
  almacen           Almacen?         @relation(fields: [almacenId], references: [id])
  movimientoEntrada MovimientoStock? @relation("SerieMovimientoEntrada", fields: [movimientoEntradaId], references: [id])
  movimientoSalida  MovimientoStock? @relation("SerieMovimientoSalida", fields: [movimientoSalidaId], references: [id])

  @@unique([empresaId, skuId, numeroSerie])
  @@index([empresaId, skuId, estado])
  @@index([empresaId, almacenId])
  @@map("serie_articulo")
}
